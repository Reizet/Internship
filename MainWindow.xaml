<Window x:Class="BudgetTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Budget Tracker"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="18"
                Margin="0 0 0 15">

            <Grid>
                <StackPanel>
                    <TextBlock Text="Облік особистого бюджету"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    
                </StackPanel>

                <Button Content="Звіт"
                        Width="110"
                        Height="34"
                        Background="#059669"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="ReportsButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="15"
                Margin="0 0 0 15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="145"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="115"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="4">
                    <TextBlock Text="Тип запису" FontSize="13" Foreground="#374151"/>
                    <ComboBox x:Name="TypeComboBox">
                        <ComboBoxItem Content="Дохід"/>
                        <ComboBoxItem Content="Витрата"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="4">
                    <TextBlock Text="Категорія" FontSize="13" Foreground="#374151"/>
                    <TextBox x:Name="CategoryTextBox"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="4">
                    <TextBlock Text="Тег / підкатегорія" FontSize="13" Foreground="#374151"/>
                    <TextBox x:Name="TagTextBox"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="4">
                    <TextBlock Text="Сума" FontSize="13" Foreground="#374151"/>
                    <TextBox x:Name="AmountTextBox"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="4">
                    <TextBlock Text="Дата" FontSize="13" Foreground="#374151"/>
                    <DatePicker x:Name="DatePicker"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="4">
                    <TextBlock Text="Опис" FontSize="13" Foreground="#374151"/>
                    <TextBox x:Name="DescriptionTextBox"/>
                </StackPanel>

                <Button Grid.Column="6"
                        Content="Додати"
                        Margin="4"
                        VerticalAlignment="Bottom"
                        Height="32"
                        Click="AddButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="10">

            <DataGrid x:Name="RecordsDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="150"/>
                    <DataGridTextColumn Header="Тег" Binding="{Binding Tag}" Width="150"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding Amount}" Width="110"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="120"/>
                    <DataGridTextColumn Header="Опис" Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="12"
                Margin="0 15 0 0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="PeriodComboBox"
                          Grid.Column="0"
                          Margin="4"
                          SelectionChanged="PeriodComboBox_SelectionChanged">
                    <ComboBoxItem Content="За місяць"/>
                    <ComboBoxItem Content="За пів року"/>
                    <ComboBoxItem Content="За рік"/>
                </ComboBox>

               

                <Button Grid.Column="1"
                        Content="Видалити"
                        Margin="4"
                        Background="#DC2626"
                        Click="DeleteButton_Click"/>

                <TextBlock x:Name="SummaryTextBlock"
                           Grid.Column="3"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="10 0"/>
            </Grid>
        </Border>
    </Grid>
</Window>